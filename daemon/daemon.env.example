# /etc/edo/daemon.env  --  600 root:root
# Shared HMAC key. Generate with: python -c 'import secrets; print(secrets.token_hex(32))'
EDO_DAEMON_HMAC_KEY=CHANGE_ME_TO_A_LONG_RANDOM_STRING
EDO_DAEMON_SOCKET=/run/edo/edo-daemon.sock
EDO_DAEMON_STATE=/var/lib/edo/state.json
EDO_SOCKET_OWNER=root:ctfd
EDO_VPN_SUBNET=10.9.0.0/24
EDO_VPN_ENDPOINT=vpn.example.com:51820
EDO_WG_INTERFACE=wg0
EDO_DOCKER_NET=edo_team_
