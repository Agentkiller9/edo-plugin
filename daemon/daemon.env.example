# /etc/edo/daemon.env  --  600 root:root

# The UID the CTFd process runs inside its container as. This is the actual
# authentication boundary (SO_PEERCRED) — any connection from a different
# non-root UID is rejected. The stock ctfd/ctfd Docker image runs as 1001;
# confirm with `docker compose exec ctfd id -u`.
EDO_ALLOWED_UID=1001

EDO_SOCKET_PATH=/run/edo/edo.sock
EDO_STATE_DB=/var/lib/edo/edo-daemon.db
# root:<group> — the group must have GID matching EDO_ALLOWED_UID's container
# user so the bind-mounted socket is readable from inside the CTFd container.
EDO_SOCKET_OWNER=root:ctfd_socket

EDO_VPN_ENDPOINT=vpn.example.com:51820
EDO_VPN_PORT=51820

# Cap on simultaneous docker build/create operations (protects against a
# burst of "spawn" clicks forking off dozens of builds at once).
EDO_MAX_CONCURRENT_SPAWNS=4
