# Copy to `.env`, fill in, then `docker compose up -d --build`.
# `.env` is git-ignored — DO NOT commit it.

# Shared HMAC key for daemon RPC. Generate once with:
#   openssl rand -hex 32
# Set this EXACT value on both sides:
#   - here (this file), AND
#   - /etc/edo/daemon.env on the host (as EDO_DAEMON_HMAC_KEY=...)
EDO_DAEMON_HMAC_KEY=
